# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:5173

# Supabase Postgres connection string.
# In Supabase, use the pooled connection string for deployed apps and the direct connection locally if available.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public"

# Auth
# dev = accepts x-user-id header for local school demo; strict = bearer token required.
AUTH_MODE=dev
SUPABASE_JWT_SECRET=
ADMIN_EMAIL=

# Optional external API fallback. Not needed for the core PlateSense engine.
SPOONACULAR_API_KEY=
