# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:5173

# Runtime uses the transaction pooler with enough connections for concurrent dashboard queries.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30&sslmode=require"
# Migrations use the session pooler.
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[POOLER-HOST]:5432/postgres?sslmode=require"

# Auth
# dev = accepts x-user-id header for local school demo; strict = bearer token required.
AUTH_MODE=dev
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_SECRET=
# Optional. Authenticated recipe uploads use the caller bearer token and the
# recipe-images RLS policies. Set this only for trusted server-side storage work.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=
# Transactional welcome email sent after a user confirms their signup code.
RESEND_API_KEY=

# Catalog import. Defaults match the linked project's existing buckets. When a
# service role is omitted, reconciliation lists them through the logged-in CLI.
CATALOG_RECIPE_IMAGE_BUCKET=recipe-images
CATALOG_INGREDIENT_IMAGE_BUCKET=ingredient-images
# Optional Supabase Auth user id for Platform Admin. ADMIN_EMAIL alone is enough
# after that admin has signed in once and created a matching User row.
CATALOG_ADMIN_USER_ID=
# Optional overrides; defaults point to the repository info/ and assets/ folders.
CATALOG_INFO_DIR=
CATALOG_ASSET_DIR=

# Optional external API fallback. Not needed for the core PlateSense engine.
SPOONACULAR_API_KEY=
